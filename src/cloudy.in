#
# Configured launcher for Cloudy. Meson substitutes the @...@ tokens.

import os
import sys
import signal
import locale
import gettext

VERSION = '@VERSION@'
APP_ID = '@APP_ID@'
pkgdatadir = '@pkgdatadir@'
localedir = '@localedir@'

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)

try:
    locale.bindtextdomain('cloudy', localedir)
    locale.textdomain('cloudy')
except (locale.Error, AttributeError):
    pass
gettext.install('cloudy', localedir)

if __name__ == '__main__':
    import gi

    from gi.repository import Gio
    resource = Gio.Resource.load(
        os.path.join(pkgdatadir, APP_ID + '.gresource'))
    getattr(resource, "register", resource._register)()

    from cloudy import main
    sys.exit(main.main(VERSION, APP_ID))
