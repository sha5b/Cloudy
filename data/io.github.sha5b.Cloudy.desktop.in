[Desktop Entry]
Name=Cloudy
GenericName=Cloud Storage & Mail
# Translators: search keywords, separated by semicolons, not shown to the user
Comment=Use OneDrive, SharePoint and unified mail on your desktop
Keywords=OneDrive;SharePoint;Microsoft 365;Cloud;Sync;Mail;Calendar;Files;
Exec=cloudy %U
Icon=io.github.sha5b.Cloudy
Terminal=false
Type=Application
Categories=GNOME;GTK;Network;FileTransfer;Email;Calendar;
MimeType=x-scheme-handler/mailto;text/calendar;x-scheme-handler/webcal;
StartupNotify=true
DBusActivatable=true
