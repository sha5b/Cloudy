<schemalist gettext-domain="clouddrive">
  <schema id="com.fiberelements.Clouddrive" path="/com/fiberelements/Clouddrive/">

    <key name="window-width" type="i">
      <default>900</default>
      <summary>Window width</summary>
    </key>

    <key name="window-height" type="i">
      <default>640</default>
      <summary>Window height</summary>
    </key>

    <key name="window-maximized" type="b">
      <default>false</default>
      <summary>Window maximized state</summary>
    </key>

    <key name="enabled-modules" type="as">
      <default>['microsoft365']</default>
      <summary>Identifiers of enabled service modules</summary>
      <description>
        Which modules the module engine should activate at startup.
      </description>
    </key>

    <key name="last-active-view" type="s">
      <default>'welcome'</default>
      <summary>The view shown when the app was last closed</summary>
    </key>

    <key name="accounts" type="s">
      <default>'[]'</default>
      <summary>Configured accounts, serialized as a JSON array</summary>
      <description>
        Non-secret account metadata (id, display name, provider, module).
        Tokens are stored separately via libsecret.
      </description>
    </key>

  </schema>
</schemalist>
