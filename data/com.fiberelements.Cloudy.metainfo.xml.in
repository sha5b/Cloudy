<component type="desktop-application">
  <id>com.fiberelements.Cloudy</id>

  <name>Cloudy</name>
  <summary>Use OneDrive, SharePoint and unified mail on your desktop</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="com.fiber-elements">
    <name>Fiber Elements</name>
  </developer>

  <description>
    <p>
      Cloudy is a GNOME-native app that makes Microsoft OneDrive for
      Business — including Teams and SharePoint document libraries — easy to use
      on Linux, with file-manager integration, selective and on-demand sync, and
      a unified mail and calendar surface for Microsoft 365 and Google accounts.
    </p>
    <p>
      It orchestrates proven Linux backends rather than reinventing them, behind
      one adaptive, modular interface.
    </p>
  </description>

  <launchable type="desktop-id">com.fiberelements.Cloudy.desktop</launchable>

  <content_rating type="oars-1.1" />

  <url type="homepage">https://github.com/sha5b/Clouddrive-Fedora</url>
  <url type="bugtracker">https://github.com/sha5b/Clouddrive-Fedora/issues</url>
  <url type="vcs-browser">https://github.com/sha5b/Clouddrive-Fedora</url>

  <translation type="gettext">cloudy</translation>

  <!--
    Screenshots are required by AppStream for catalog visibility. Add them once
    the UI exists, e.g.:
    <screenshots>
      <screenshot type="default">
        <image>https://.../files-view.png</image>
        <caption>Browsing a SharePoint library</caption>
      </screenshot>
    </screenshots>
  -->

  <releases>
    <release version="0.1.0" date="2026-06-14">
      <description>
        <p>Initial project scaffold and application shell.</p>
      </description>
    </release>
  </releases>
</component>
