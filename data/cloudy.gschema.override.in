# GSettings vendor override — GENERATED at build time from meson options.
# Fills the (empty) credential defaults for shipped builds. Installed next to
# the schema and merged by glib-compile-schemas. Not present in dev builds.
[io.github.sha5b.Cloudy]
microsoft-client-id='@MS_CLIENT_ID@'
google-client-id='@GOOGLE_CLIENT_ID@'
google-client-secret='@GOOGLE_CLIENT_SECRET@'
