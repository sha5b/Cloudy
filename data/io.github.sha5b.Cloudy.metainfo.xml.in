<component type="desktop-application">
  <id>io.github.sha5b.Cloudy</id>

  <name>Cloudy</name>
  <summary>OneDrive, SharePoint and unified mail and calendar</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="io.github.sha5b">
    <name>Shahab Nedaei</name>
  </developer>

  <description>
    <p>
      Cloudy brings Microsoft 365 and Google into one GNOME-native window. It
      mounts OneDrive, SharePoint and Teams libraries as live network drives in
      your file manager, and gives mail, calendar and chat from both Microsoft
      and Google one consistent, provider-agnostic surface.
    </p>
    <p>
      It orchestrates proven backends — rclone for the file mounts, and the
      Microsoft Graph and Google REST APIs for mail, calendar and chat — rather
      than reinventing them, behind one adaptive interface.
    </p>
    <p>Features:</p>
    <ul>
      <li>Microsoft 365 (OneDrive, SharePoint and Teams libraries) and Google (Gmail, Calendar, Drive) accounts side by side</li>
      <li>Files mounted as live two-way network drives, visible in GNOME Files and an in-app browser</li>
      <li>Mail with read, compose and reply, plus Me / Teams / Shared mailbox sources</li>
      <li>A month calendar and agenda with event create, edit, delete and RSVP</li>
      <li>Chat for Teams chats (work/school) and Google Chat (Workspace) — 1:1, group and meeting threads with images, reactions, mentions and live updates</li>
      <li>A dashboard aggregating upcoming events, recent mail and recent file changes across every account</li>
      <li>Desktop integration: system mail and calendar handler, new-mail notifications, and file-manager status</li>
      <li>Tokens stored securely in the system keyring — never in plain text</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.sha5b.Cloudy.desktop</launchable>

  <content_rating type="oars-1.1" />

  <url type="homepage">https://github.com/sha5b/Cloudy</url>
  <url type="bugtracker">https://github.com/sha5b/Cloudy/issues</url>
  <url type="vcs-browser">https://github.com/sha5b/Cloudy</url>

  <keywords>
    <keyword>OneDrive</keyword>
    <keyword>SharePoint</keyword>
    <keyword>Microsoft 365</keyword>
    <keyword>Teams</keyword>
    <keyword>Google</keyword>
    <keyword>Gmail</keyword>
    <keyword>Cloud</keyword>
    <keyword>Sync</keyword>
    <keyword>Mail</keyword>
    <keyword>Calendar</keyword>
    <keyword>Chat</keyword>
    <keyword>Files</keyword>
  </keywords>

  <branding>
    <color type="primary" scheme_preference="light">#d5d7da</color>
    <color type="primary" scheme_preference="dark">#1d1d1d</color>
  </branding>

  <translation type="gettext">cloudy</translation>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/sha5b/Cloudy/main/data/screenshots/calendar.png</image>
      <caption>A month calendar and agenda across all your accounts</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/sha5b/Cloudy/main/data/screenshots/files-libraries.png</image>
      <caption>OneDrive, SharePoint and Teams libraries mounted as live drives</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/sha5b/Cloudy/main/data/screenshots/mail.png</image>
      <caption>Unified mail with Me, Teams and Shared sources</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/sha5b/Cloudy/main/data/screenshots/files-browser.png</image>
      <caption>Browse mounted libraries inside the app</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.3.2" date="2026-07-14">
      <description>
        <p>Meeting invitations finally get first-class treatment, and this release fixes a batch of provider-API mistakes found in a full audit.</p>
        <ul>
          <li>Meeting invitations in Mail now show a proper invite card with Accept / Tentative / Decline and a Join link — and answering updates the organizer's tracking correctly</li>
          <li>New invitations raise a "You're invited" notification and the Calendar tab shows a badge with your unanswered invitations</li>
          <li>Invite emails are marked with a calendar icon in the message list</li>
          <li>Nested Outlook mail folders (folders inside folders) are now listed and reachable</li>
          <li>Secondary and shared-in calendars now appear alongside your default calendar</li>
          <li>Large attachments (over ~3 MB) can now be sent; forwards keep the original formatting, inline images and attachments; replies keep the quoted conversation</li>
          <li>Replying in Teams/group conversations works (needs one re-sign-in); files sent in chats are now openable by the recipients</li>
          <li>The Nautilus extension no longer freezes the file manager while Cloudy is busy</li>
          <li>Google: multiple calendars actually aggregate now, editing chat messages works, your own chat messages show on the right side, non-UTF-8 mail displays correctly, and busy months are no longer truncated</li>
        </ul>
      </description>
    </release>
    <release version="0.3.1" date="2026-07-13">
      <description>
        <p>A stability sweep: reliable chat, correct calendar times, and a desktop that stays fast with mounted drives.</p>
        <ul>
          <li>Chat: new messages arrive reliably, and loading older messages no longer shows duplicates or makes messages vanish</li>
          <li>Chat list groups meeting and call chats under their own section, ordered by latest activity</li>
          <li>File-open dialogs across the desktop no longer crawl or hang when a cloud drive is mounted</li>
          <li>Rename and New folder in the file browser work again; copying never overwrites an existing file</li>
          <li>The Nautilus "Copy Share Link" action actually copies the link now</li>
          <li>Editing a calendar event no longer silently shifts its time; live badges and countdowns show correctly</li>
          <li>Declined invitations explain Outlook's "Save declined events" setting instead of showing a raw error</li>
          <li>Google: sign-in no longer fails intermittently, attendees receive invitation emails, and Gmail folders load much faster with inline images shown</li>
          <li>Drafts keep their Cc/Bcc when reopened, and mail lists no longer duplicate rows after a refresh</li>
          <li>Unmounting reports honestly, stale mounts are cleaned automatically, and each account keeps its own drive credentials</li>
        </ul>
      </description>
    </release>
    <release version="0.3.0" date="2026-07-10">
      <description>
        <p>Group chats, reliable file uploads, and a correct GNOME calendar.</p>
        <ul>
          <li>Start a group chat by adding several people to a new chat, or add people to an existing one-to-one chat</li>
          <li>Files uploaded to SharePoint/OneDrive Office documents now reach the server reliably instead of silently retrying forever</li>
          <li>The Files view shows live per-drive sync status: Uploading, Synced, or didn't upload</li>
          <li>Fixed GNOME Calendar showing event times shifted by a couple of hours; existing wrong events are corrected on upgrade</li>
          <li>Calendar changes made elsewhere (phone or Outlook) now update GNOME Calendar in the background</li>
          <li>Forgotten mounts and stale file-manager bookmarks are reconciled at startup so writes can't vanish into a local stub</li>
          <li>The Nautilus "Copy share link" action now copies a real OneDrive/SharePoint link instead of doing nothing</li>
          <li>Undo button on file actions (Trash, Rename, Move, Copy) to take them back</li>
          <li>Drag and drop files in the in-app file browser — drag out to other apps, or drop in to upload</li>
          <li>Fixed chats intermittently failing to open and a crash on one-to-one chats</li>
          <li>Forwarded chat messages now show their content instead of just an attachment</li>
          <li>The chat no longer jumps around when you react to a message</li>
          <li>Click a forwarded message to jump to the original message it came from</li>
          <li>Sent files now appear immediately, and deleted messages stay gone, without needing a refresh</li>
        </ul>
      </description>
    </release>
    <release version="0.2.9" date="2026-07-07">
      <description>
        <p>Meeting invites land on your calendar, mail gets organized, and stale data is gone.</p>
        <ul>
          <li>Accepting a meeting invite from Mail now updates your own calendar too, and a cancellation mail can remove the event</li>
          <li>Right-click a message to mark it unread, flag it for follow-up, or move it to another folder</li>
          <li>Save drafts from the composer and resume them later from the Drafts folder</li>
          <li>Edited events no longer show their old time on the Dashboard or Calendar — caches refresh after every change</li>
          <li>Fixed the calendar failing to load with a timezone error (CEST) on European systems</li>
          <li>Fixed event, message and compose windows getting stuck on their loading spinner</li>
          <li>A single malformed message or event from the server no longer blanks the whole list</li>
          <li>Invitations opened from .ics files keep their full title and description</li>
        </ul>
      </description>
    </release>
    <release version="0.2.8" date="2026-06-29">
      <description>
        <p>A bug-fix and cleanup release focused on correctness, performance and trust.</p>
        <ul>
          <li>Mail and Chat lists now update in place, preserving your scroll position and selection</li>
          <li>Switching between Mail, Calendar and Chat is faster thanks to a per-account API client cache</li>
          <li>Microsoft 365 share links resolve a local file back to the right OneDrive or SharePoint drive before creating the link</li>
          <li>Calendar events keep your local timezone when created or updated, and shared/group calendars route correctly</li>
          <li>Large OneNote notebooks now load every section and page instead of stopping after the first batch</li>
          <li>Meeting-invite email replies follow the iCalendar standard more reliably</li>
          <li>rclone is provisioned from a pinned version with verified SHA-256 checksums</li>
          <li>Google sign-in cleans up its local redirect server reliably after the flow finishes</li>
        </ul>
      </description>
    </release>
    <release version="0.2.7" date="2026-06-26">
      <description>
        <p>Fuller mail controls, an email signature, sending any file in Teams, and clearer errors.</p>
        <ul>
          <li>Mail now has Reply, Reply all and Forward — forwarding carries the original message's attachments</li>
          <li>Set a per-account email signature in Preferences → Accounts; it's added to new mail, replies and forwards</li>
          <li>Send any file type in a Teams chat, not just images — images still show a preview, other files show a labelled chip (up to 10 per message)</li>
          <li>Clearer error messages: Microsoft and Google failures are shown in plain language instead of raw codes</li>
          <li>Links in emails open reliably again, including in the Flatpak build, and so do the Join buttons on online meetings</li>
          <li>Reading an email now updates the unread badge instantly and clears its desktop notification</li>
          <li>Deleting a Teams message updates the conversation immediately</li>
          <li>The Activity overview lays out cleanly in balanced columns instead of leaving large empty gaps</li>
          <li>The Files right-click integration no longer slows the file manager — it answers locally instead of asking Cloudy about every file you select</li>
        </ul>
      </description>
    </release>
    <release version="0.2.6" date="2026-06-23">
      <description>
        <p>Live updates everywhere, start-and-join online meetings, and a redesigned Activity overview.</p>
        <ul>
          <li>Activity, Calendar, Teams and Mail now update on their own as new mail, invites and posts arrive — no manual refresh — and the calendar marks events that are happening now</li>
          <li>The Activity page is redesigned as a clean multi-column overview, grouped by what needs you: happening now, invites awaiting a reply, mentions, mail and chats</li>
          <li>Start an online meeting from Cloudy: an "Online meeting" switch when creating an event (Teams or Google Meet), a "Meet now" button, and one-tap Join buttons — plus a meeting-starting alert with Join and a ring</li>
          <li>Meeting-invite emails now show the time, place and a Join button, and flag updated or cancelled meetings</li>
          <li>Mounted drives come back on their own — after a reboot, or if a drive drops out, Cloudy remounts the ones you had open and reconnects a drive whose connection died</li>
          <li>Search your whole mailbox: type to filter the open list instantly, or press Enter to search the entire folder on the server and find older mail</li>
          <li>The file browser can select several items at once and copy or move them to another folder — copy to a local folder to download files off a cloud drive</li>
          <li>More reliable behind the scenes: long lists of folders, contacts and calendars are no longer cut off, Reply all keeps everyone on Gmail, and Google sign-in is more secure</li>
        </ul>
      </description>
    </release>
    <release version="0.2.5" date="2026-06-21">
      <description>
        <p>Clearer mail headers and a more accurate Chat presence.</p>
        <ul>
          <li>The message header now spells out the sender's full email address along with the To, Cc and Bcc recipients — and every address is one click to copy</li>
          <li>Double-click a message in the list to open it in its own window, so you can read it next to the list and other mail</li>
          <li>Chat presence dots are now accurate: contacts who have gone offline no longer keep a stale "online" dot</li>
        </ul>
      </description>
    </release>
    <release version="0.2.4" date="2026-06-18">
      <description>
        <p>Meeting invitations you can answer, and a new Activity feed.</p>
        <ul>
          <li>Accept, Tentative or Decline calendar invites — now working for both Microsoft and Google accounts, with your current answer shown clearly</li>
          <li>Invites you haven't answered still appear in the calendar, dimmed and clickable, so you don't miss them</li>
          <li>Meeting-invite emails now carry Accept / Tentative / Decline buttons that reply to the organiser with a standard calendar response</li>
          <li>New Activity tab — the first tab on launch — a single feed of recent mail, upcoming and unanswered invites, recent chats, plus "reacted to your message" and "mentioned you"</li>
          <li>The image viewer now zooms with the scroll wheel and pans by dragging</li>
          <li>Several images in one chat message show as a wrapping gallery instead of a tall stack</li>
          <li>Optional read-receipt request when composing mail (Microsoft accounts)</li>
        </ul>
      </description>
    </release>
    <release version="0.2.3" date="2026-06-17">
      <description>
        <p>A more live, more robust Chat — plus fixes across the app.</p>
        <ul>
          <li>The chat list updates live: a new message moves its conversation to the top and marks it unread, no manual refresh</li>
          <li>Replies show a clickable quote of the message they answer (and jump to it) instead of a bare "attachment"</li>
          <li>Flat chat avatars; sent messages appear and scroll to the bottom instantly, including images</li>
          <li>Attach several images to a chat message at once, and send multiple images without the "invalid payload" error</li>
          <li>A chat message that fails to send now stays in place with a Retry button to resend it</li>
          <li>The conversation you're in jumps to the top of the list the moment you send or receive a message</li>
          <li>Large chat and OneNote images are downscaled while decoding, so a huge picture can't crash the renderer</li>
          <li>New General setting to turn the Nautilus file-manager integration on or off</li>
          <li>Fixes across Mail, Calendar, Files and the Dashboard (text escaping, a couple of crashes, a popover leak)</li>
        </ul>
      </description>
    </release>
    <release version="0.2.2" date="2026-06-16">
      <description>
        <p>Smarter notifications, Google parity, and a command palette.</p>
        <ul>
          <li>Notification attention controls: honour system Do Not Disturb, optional quiet hours, a relevance level, and per-chat/per-channel mute — with low-priority alerts batched into a periodic digest</li>
          <li>Google multi-calendar: the agenda now merges every calendar you show (birthdays, holidays, subscribed and secondary), not just your primary</li>
          <li>Google Drive: the Files tab lists My Drive, Shared with me and your Shared Drives</li>
          <li>Command palette (Ctrl+K) to jump to any account, mailbox, calendar or chat</li>
          <li>Offline cache: mail and agenda show last-known data instantly on launch, even offline</li>
          <li>Dashboard Activity feed of starred channels and recent chats; star channels and chats</li>
          <li>Notification settings moved to their own tab; OneNote and Gmail layout fixes</li>
          <li>The mail list now updates on its own when new mail arrives, not only on a manual refresh</li>
          <li>Fixed the Files tab for Microsoft accounts not listing OneDrive and Team libraries</li>
          <li>File-manager integration no longer stalls the app or Nautilus when a network drive is slow to respond</li>
          <li>The Mail and Chat tabs now show a live unread-count badge, like the account list</li>
          <li>Inline images in the mail composer now appear after you insert them, and you can paste an image straight from the clipboard with Ctrl+V</li>
        </ul>
      </description>
    </release>
    <release version="0.2.1" date="2026-06-15">
      <description>
        <p>Teams channels and OneNote.</p>
        <ul>
          <li>New Teams tab: pick a team and channel to read its posts (with threaded replies) and post or reply</li>
          <li>Each channel has a Notes tab backed by the team's OneNote notebook — browse sections and pages, read them (with inline images), and create or edit pages</li>
          <li>Flatpak builds no longer depend on gitlab.gnome.org being reachable</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-06-15">
      <description>
        <p>Chat, packaging and shared-source release.</p>
        <ul>
          <li>Teams-style messenger (Teams chats and Google Chat): 1:1, group and meeting threads with inline images, reactions, @mentions, edit/delete, presence and live updates</li>
          <li>Fedora RPM and single-file Flatpak bundle, with OAuth client IDs baked in at build time</li>
          <li>Shared / group Mail and Calendar sources (Me / Teams / Shared) with pinnable sources on the Dashboard</li>
          <li>Calendar month grid, non-modal event window with RSVP tracker and inline edit</li>
          <li>Standalone image viewer and rich-text editor widgets</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-06-15">
      <description>
        <p>First preview release.</p>
        <ul>
          <li>Microsoft 365 and Google sign-in</li>
          <li>OneDrive, SharePoint and Teams libraries mounted as live drives, with an in-app file browser</li>
          <li>Unified mail (read, compose, reply) and a month calendar with event create, edit, delete and RSVP</li>
          <li>Dashboard aggregating events, mail and file changes across accounts</li>
          <li>Desktop and file-manager integration; tokens stored in the system keyring</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
