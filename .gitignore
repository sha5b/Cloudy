# Secrets — never commit. Real creds live in ~/.config/cloudy/secrets.env
# (outside the repo). These patterns are a defensive backstop.
secrets.env
*.secret
*.local
credentials.json
client_secret*.json

# Build output
/_build/
/build/
/builddir/
/_install/
/.flatpak-builder/
/repo/
*.flatpak

# Meson subproject sources (kept as .wrap files only)
/subprojects/blueprint-compiler/
/subprojects/*/
/subprojects/*.wraplock

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store

# Generated translation artifacts
/po/*.gmo
/po/*.mo
