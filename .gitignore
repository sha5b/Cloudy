# Secrets — never commit. Copy .env.example to .env and fill it in.
# Ignore every .env variant; keep ONLY the committed template.
.env
.env.*
!.env.example
secrets.env
*.secret
*.local
*.key
*.pem
credentials.json
client_secret*.json
# Editor swap/backup files that could capture secrets
*~
*.bak

# Build output
/_build/
/build/
/builddir/
/_install/
/.flatpak-builder/
/repo/
/release/
*.flatpak

# Meson subproject sources (kept as .wrap files only)
/subprojects/blueprint-compiler/
/subprojects/*/
/subprojects/*.wraplock

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store

# Generated translation artifacts
/po/*.gmo
/po/*.mo
static/
